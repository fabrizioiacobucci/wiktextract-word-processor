{
    "compilerOptions": {
        "target": "ES2022",
        "module": "Node16",
        "moduleResolution": "Node16",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "noImplicitAny": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "types": ["node"],
        "allowImportingTsExtensions": true,
        "noEmit": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules"]
}
